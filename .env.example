# Anthropic API Key for Claude
ANTHROPIC_API_KEY=your_api_key_here

# Model Configuration
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Agent Configuration
MAX_ITERATIONS=15
VERBOSE=true

# Vector Store
VECTOR_STORE_PATH=./data/vector_store

# Cache Configuration
ENABLE_CACHE=true
CACHE_PATH=./data/cache
