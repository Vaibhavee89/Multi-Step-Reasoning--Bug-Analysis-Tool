# LLM API Keys (Configure at least one)
# Primary: Claude (Anthropic) - Best quality
ANTHROPIC_API_KEY=your_api_key_here

# Fallback: Groq - Free tier available, fast inference
GROQ_API_KEY=your_groq_api_key_here

# Model Configuration
CLAUDE_MODEL=claude-sonnet-4-5-20250929
GROQ_MODEL=llama-3.3-70b-versatile

# Agent Configuration
MAX_ITERATIONS=15
VERBOSE=true

# Vector Store
VECTOR_STORE_PATH=./data/vector_store

# Cache Configuration
ENABLE_CACHE=true
CACHE_PATH=./data/cache

# Security Vulnerability Tracking
# NVD API Key - Optional but recommended (increases rate limit from 5 to 50 req/30s)
# Get free API key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# Enable/disable internet-enabled security tools
ENABLE_INTERNET_TOOLS=true

# Vulnerability cache settings
CACHE_VULNERABILITIES=true
VULNERABILITY_CACHE_TTL=3600  # Cache TTL in seconds (1 hour)

# API Configuration
OSV_API_TIMEOUT=10  # OSV.dev API timeout in seconds
NVD_API_TIMEOUT=10  # NVD API timeout in seconds
MAX_API_RETRIES=3   # Maximum retry attempts for failed API calls
